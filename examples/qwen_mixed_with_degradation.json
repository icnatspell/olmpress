{
    "input_model": {
        "type": "HfModel",
        "model_path": "Qwen/Qwen2.5-1.5B-Instruct"
    },
    "systems": {
        "local_system": {
            "type": "LocalSystem",
            "accelerators": [
                { "execution_providers": ["CUDAExecutionProvider"] }
            ]
        }
    },
    "evaluators": {
        "lm_eval": {
            "type": "LMEvaluator",
            "tasks": ["arc_challenge", "arc_easy", "mmlu", "hellaswag"],
            "batch_size": 32,
            "provider_options": { "enable_skip_layer_norm_strict_mode": "1" }
        },
        "degradation": {
            "type": "olmpress_degradation",
            "reference_model": {
                "type": "HfModel",
                "config": { "model_path": "Qwen/Qwen2.5-1.5B-Instruct" }
            },
            "inputs": {
                "input_ids": {
                    "shape": [1, 64],
                    "dtype": "long",
                    "low": 0,
                    "high": 151936,
                    "seed": 0
                }
            },
            "view": "linears",
            "logits_layer": "lm_head",
            "temperature": 1.0,
            "metrics": [
                {
                    "name": "deg",
                    "type": "custom",
                    "sub_types": [
                        { "name": "sqnr_mean" },
                        { "name": "sqnr_min" },
                        { "name": "cosine_mean" },
                        { "name": "relative_l2_max" },
                        { "name": "kl" }
                    ]
                }
            ]
        }
    },
    "passes": {
        "s": {
            "type": "SelectiveMixedPrecision",
            "algorithm": "k_quant_down"
        },
        "g": {
            "type": "gptq",
            "bits": 4,
            "sym": true,
            "group_size": 32,
            "lm_head": true
        },
        "m": {
            "type": "ModelBuilder",
            "precision": "int4"
        }
    },
    "evaluator": "degradation",
    "evaluate_input_model": false,
    "target": "local_system",
    "log_severity_level": 1,
    "output_dir": "models/qwen2.5-1.5b-mixed",
    "cache_dir": "cache",
    "no_artifacts": true
}
