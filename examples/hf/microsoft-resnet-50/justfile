# Full pipeline for the HF microsoft/resnet-50 pruning + fine-tuning example.
#
# Run from this directory:
#   just all
#   just all prune=0               # skip pruning, reuse existing .pt
#   just all finetune_plain=0      # skip plain fine-tuning
#   just all train_samples=500 epochs=2   # quick smoke run
#
# Or run a single phase:
#   just eval-base
#   just prune
#   just eval-pruned
#   just finetune-plain
#   just finetune-kd

root := justfile_directory() / ".." / ".." / ".."

pruned        := root / "examples/hf/microsoft-resnet-50/outputs/lamp_0.10/model/model.pt"
finetuned_ft  := root / "examples/hf/microsoft-resnet-50/outputs/lamp_0.10/model/model_ft.pt"
finetuned_kd  := root / "examples/hf/microsoft-resnet-50/outputs/lamp_0.10/model/model_kd.pt"

# Hyperparameters
eval_samples  := "1000"
train_samples := "10000"
epochs        := "10"

# Phase toggles — set to "0" to skip a phase
eval_base      := "1"
prune          := "1"
eval_pruned    := "1"
finetune_plain := "1"
finetune_kd    := "1"

default:
    @just --justfile {{ justfile() }} --list

# Run all phases in sequence, then print a results summary table
all:
    #!/usr/bin/env bash
    set -euo pipefail
    cd {{ root }}
    _tmp=$(mktemp)
    trap 'rm -f "$_tmp"' EXIT
    _jf="{{ justfile() }}"
    _es="{{ eval_samples }}"
    _ts="{{ train_samples }}"
    _ep="{{ epochs }}"

    base_top1="-"   base_params="-"
    pruned_top1="-" pruned_params="-"
    ft_top1="-"     ft_params="-"
    kd_top1="-"     kd_params="-"

    _fmt_acc()    { if [ "$1" = "-" ] || [ -z "$1" ]; then echo "      -"; return; fi; python3 -c "print(f'{$1*100:6.2f}%')"; }
    _fmt_params() { if [ "$1" = "-" ] || [ -z "$1" ]; then echo "             -"; return; fi; python3 -c "print(f'{$1:>14,}')"; }

    if [ "{{ eval_base }}" = "1" ]; then
        echo "=== Phase 0: eval base (unpruned) ==="
        just --justfile "$_jf" eval_samples="$_es" eval-base | tee "$_tmp"
        base_top1=$(grep -m1 '^top1='    "$_tmp" | cut -d= -f2)
        base_params=$(grep -m1 '^params=' "$_tmp" | cut -d= -f2)
    fi
    if [ "{{ prune }}" = "1" ]; then
        echo "=== Phase 1: prune with Olive ==="
        just --justfile "$_jf" prune
    fi
    if [ "{{ eval_pruned }}" = "1" ]; then
        echo "=== Phase 2: eval pruned (before fine-tuning) ==="
        just --justfile "$_jf" eval_samples="$_es" eval-pruned | tee "$_tmp"
        pruned_top1=$(grep -m1 '^top1='    "$_tmp" | cut -d= -f2)
        pruned_params=$(grep -m1 '^params=' "$_tmp" | cut -d= -f2)
    fi
    if [ "{{ finetune_plain }}" = "1" ]; then
        echo "=== Phase 3: plain CE fine-tuning + eval ==="
        just --justfile "$_jf" eval_samples="$_es" train_samples="$_ts" epochs="$_ep" finetune-plain | tee "$_tmp"
        ft_top1=$(grep -m1 '^top1='    "$_tmp" | cut -d= -f2)
        ft_params=$(grep -m1 '^params=' "$_tmp" | cut -d= -f2)
    fi
    if [ "{{ finetune_kd }}" = "1" ]; then
        echo "=== Phase 4: KD fine-tuning + eval ==="
        just --justfile "$_jf" eval_samples="$_es" train_samples="$_ts" epochs="$_ep" finetune-kd | tee "$_tmp"
        kd_top1=$(grep -m1 '^top1='    "$_tmp" | cut -d= -f2)
        kd_params=$(grep -m1 '^params=' "$_tmp" | cut -d= -f2)
    fi

    echo ""
    printf "%-24s  %8s  %14s\n" "Model" "acc@1" "#params"
    printf "%-24s  %8s  %14s\n" "------------------------" "--------" "--------------"
    printf "%-24s  %8s  %14s\n" "Unpruned"            "$(_fmt_acc  "$base_top1")"    "$(_fmt_params "$base_params")"
    printf "%-24s  %8s  %14s\n" "Pruned (no FT)"      "$(_fmt_acc  "$pruned_top1")"  "$(_fmt_params "$pruned_params")"
    printf "%-24s  %8s  %14s\n" "Pruned + FT (plain)" "$(_fmt_acc  "$ft_top1")"      "$(_fmt_params "$ft_params")"
    printf "%-24s  %8s  %14s\n" "Pruned + FT (KD)"    "$(_fmt_acc  "$kd_top1")"      "$(_fmt_params "$kd_params")"
    echo ""

# Phase 0: evaluate unpruned baseline
eval-base:
    #!/usr/bin/env bash
    cd {{ root }}
    uv run python examples/hf/microsoft-resnet-50/eval.py \
        --num-samples {{ eval_samples }}

# Phase 1: prune with Olive
prune:
    #!/usr/bin/env bash
    cd {{ root }}
    uv run chisel run --config examples/hf/microsoft-resnet-50/workflow.yaml

# Phase 2: evaluate pruned model
eval-pruned:
    #!/usr/bin/env bash
    cd {{ root }}
    uv run python examples/hf/microsoft-resnet-50/eval.py \
        --model {{ pruned }} --num-samples {{ eval_samples }}

# Phase 3: plain CE fine-tuning + eval
finetune-plain:
    #!/usr/bin/env bash
    cd {{ root }}
    uv run examples/hf/microsoft-resnet-50/finetune.py \
        --model {{ pruned }} --mode plain \
        --train-samples {{ train_samples }} --eval-samples {{ eval_samples }} --epochs {{ epochs }}

# Phase 4: KD fine-tuning + eval
finetune-kd:
    #!/usr/bin/env bash
    cd {{ root }}
    uv run examples/hf/microsoft-resnet-50/finetune.py \
        --model {{ pruned }} --mode kd \
        --train-samples {{ train_samples }} --eval-samples {{ eval_samples }} --epochs {{ epochs }}
